generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CourseOverride {
  slug           String   @id
  name           String?
  priceLabel     String?
  priceAmount    Int?
  currency       String?
  scheduleLabel  String?
  durationDays   Int?
  totalHours     Int?
  dailyHours     Int?
  instructorName String?
  level          String?
  location       String?
  trainingType   String?
  heroSubtitle   String?
  updatedAt      DateTime @updatedAt
}

model CustomCourse {
  slug           String   @id
  name           String
  priceLabel     String
  priceAmount    Int?
  currency       String?
  scheduleLabel  String
  durationDays   Int
  totalHours     Int
  dailyHours     Int
  instructorName String   @default("")
  level          String
  location       String
  trainingType   String
  heroSubtitle   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DeletedCourse {
  slug      String   @id
  deletedAt DateTime @default(now())
}

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  role       String   @default("")
  quote      String
  rating     Int      @default(5)
  photoUrl   String?
  courseSlug String?
  featured   Boolean  @default(false)
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, sortOrder])
}

model Instructor {
  id        String   @id @default(cuid())
  name      String
  specialty String   @default("")
  bio       String   @default("")
  photoUrl  String?
  email     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model AssistantSettings {
  id             String   @id @default("default")
  assistantName  String   @default("لي لي")
  avatar         String   @default("")
  greeting       String   @default("")
  whatsappNumber String   @default("")
  disclaimer     String   @default("")
  enabled        Boolean  @default(true)
  leadFormEnabled Boolean @default(true)
  collectEmail   Boolean  @default(true)
  updatedAt      DateTime @updatedAt
}

model Order {
  id            String   @id @default(cuid())
  courseSlug    String
  courseName    String
  amount        Float
  currency      String
  paypalOrderId String?
  status        String   @default("pending")
  customerName  String?
  customerEmail String?
  customerPhone String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String?
  courseSlug String?
  courseName String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String?
  title      String
  content    String
  priority   Int      @default(0)
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([sourceType, sourceId])
  @@index([active])
}

model AdminSession {
  token     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model PlatformUser {
  id    String @id
  name  String
  email String
  role  String @default("trainee")

  @@index([email])
}

model ForumThread {
  id          String   @id
  courseSlug  String
  authorId    String
  authorName  String
  title       String
  body        String
  replyCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([courseSlug])
  @@index([authorId])
}

model ForumReply {
  id         String   @id
  threadId   String
  authorId   String
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([threadId])
}

model Conversation {
  id             String   @id
  participantIds String[]
  participantNames String[]
  lastMessageAt  DateTime @default(now())
  unreadCount    Int      @default(0)
  createdAt      DateTime @default(now())
}

model DirectMessage {
  id             String   @id
  conversationId String
  senderId       String
  senderName     String
  body           String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model AffiliateProfile {
  code           String @id
  name           String
  commissionRate Float  @default(0.1)
  clicks         Int    @default(0)
  conversions    Int    @default(0)
  earningsSar    Float  @default(0)
  updatedAt      DateTime @updatedAt
}
